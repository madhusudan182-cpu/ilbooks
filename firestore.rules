rules_version = '2';

/**
 * FIRESTORE SECURITY RULES
 * UPDATED: 2024-07-29T21:00:00Z - FORCING FRESH RE-DEPLOYMENT FOR CHAT AND POSTS
 * PURPOSE: Allow full access to authenticated users for community features.
 */

service cloud.firestore {
  match /databases/{database}/documents {
    // Wide open rules for all authenticated users to enable community interaction
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}