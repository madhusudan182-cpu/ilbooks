
rules_version = '2';

/**
 * FIRESTORE SECURITY RULES
 * UPDATED: 2024-07-29T18:45:00Z - FORCING FRESH RE-DEPLOYMENT
 * PURPOSE: Allow full access to authenticated users for the community prototype.
 */

service cloud.firestore {
  match /databases/{database}/documents {
    // Wide open rules for all authenticated users to resolve list/get permission errors.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
