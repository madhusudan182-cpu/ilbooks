rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ইউজার প্রোফাইল রুলস
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }

    // ফলো এবং ফ্রেন্ডশিপ রিলেশন টেবিল রুলস
    match /follows/{followId} {
      allow read, write: if request.auth != null;
    }

    // নিউজ ফিড বা পোস্টের রুলস
    match /posts/{postId} {
      // প্রোফাইল লকড এবং ব্লক লজিক আমরা ব্যাকএন্ড কোড/কোয়েরি দিয়ে হ্যান্ডেল করব, 
      // তবে এখানে শুধু লগইন করা ইউজারদের পারমিশন দেওয়া হচ্ছে।
      allow read, write: if request.auth != null;
    }
  }
}
