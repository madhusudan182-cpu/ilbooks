rules_version = '2';

/**
 * FIRESTORE SECURITY RULES
 * UPDATED: 2024-08-01T18:45:00Z - FORCING RE-DEPLOYMENT
 * PURPOSE: Grant full access to all authenticated users for real-time community features.
 */

service cloud.firestore {
  match /databases/{database}/documents {
    // Catch-all rule for all collections and subcollections
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}