
rules_version = '2';

/**
 * FIRESTORE SECURITY RULES
 * UPDATED: 2026-06-10T11:00:00Z
 * PURPOSE: Grant access to all authenticated users for prototype testing.
 */

service cloud.firestore {
  match /databases/{database}/documents {
    // Allows all read and write operations for authenticated users to ensure prototyping is smooth.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
