rules_version = '2';

/**
 * FIRESTORE SECURITY RULES
 * BROAD PERMISSIONS FOR PROTOTYPING
 * FORCE DEPLOYMENT TRIGGER: 2025-06-10T13:00:00Z
 */

service cloud.firestore {
  match /databases/{database}/documents {
    // Allows all read and write operations for all collections during the prototyping phase.
    // This is to ensure no permission barriers during development.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}