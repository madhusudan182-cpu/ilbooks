rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Force deployment trigger to resolve persistent permission issues: 2025-05-25T11:00:00Z
    
    // Global allow for prototype/development phase
    match /{document=**} {
      allow read, write: if true;
    }

    // Explicit rules for critical collections to ensure coverage
    match /users/{userId} {
      allow read, write: if true;
    }
    
    match /conversations/{convoId} {
      allow read, write: if true;
      
      match /messages/{msgId} {
        allow read, write: if true;
      }
    }
    
    match /results/{resultId} {
      allow read, write: if true;
    }
    
    match /transactions/{transactionId} {
      allow read, write: if true;
    }
    
    match /orders/{orderId} {
      allow read, write: if true;
    }
    
    match /books/{bookId} {
      allow read, write: if true;
    }
    
    match /syllabi/{level} {
      allow read, write: if true;
    }
    
    match /questions/{questionId} {
      allow read, write: if true;
    }
  }
}