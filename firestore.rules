
rules_version = '2';

/**
 * FIRESTORE SECURITY RULES
 * UPDATED: 2024-07-29T16:45:00Z
 * PURPOSE: Grant full access to all authenticated users for this community prototype.
 */

service cloud.firestore {
  match /databases/{database}/documents {
    // Standard wide-open rules for authenticated users to ensure smooth operation of social features.
    // This includes access to conversations, messages, users, and all other data.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Explicit rule for user profiles
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }

    // Explicit rules for chat to help debug any potential propagation delays
    match /conversations/{convoId} {
      allow read, write: if request.auth != null;
      match /messages/{msgId} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
