rules_version = '2';

/**
 * FIRESTORE SECURITY RULES
 * UPDATED: 2024-08-01T15:30:00Z - FORCING RE-DEPLOYMENT
 * PURPOSE: Grant full access to all authenticated users to resolve persistent permission errors.
 */

service cloud.firestore {
  match /databases/{database}/documents {
    // Catch-all rule for all collections and subcollections
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}