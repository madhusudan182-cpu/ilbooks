rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Allow full access to all collections for simplicity in this prototype.
    // In a production app, these should be restricted to authenticated users
    // and specific ownership logic.

    match /users/{userId} {
      allow read, write: if true;
    }

    match /orders/{orderId} {
       allow read, write: if true;
    }

    match /transactions/{transactionId} {
      allow read, write: if true;
    }

    match /results/{resultId} {
      allow read, write: if true;
    }

    match /conversations/{convoId} {
      allow read, write: if true;
      match /messages/{msgId} {
        allow read, write: if true;
      }
    }

    match /syllabi/{level} {
      allow read, write: if true;
    }

    match /books/{bookId} {
      allow read, write: if true;
    }

    match /questions/{questionId} {
      allow read, write: if true;
    }
    
    // Fallback for any other collections
    match /{document=**} {
      allow read, write: if true;
    }
  }
}