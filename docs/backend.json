{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Represents a user's profile information.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The user's full name." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "level": { "type": "number", "description": "The user's competition level." },
        "isAdmin": { "type": "boolean", "description": "Flag to indicate if user is an admin." }
      },
      "required": ["name", "email"]
    },
    "Order": {
      "title": "Order",
      "description": "Represents a customer's book order.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "ID of the user who placed the order." },
        "customerName": { "type": "string" },
        "deliveryAddress": { "type": "string" },
        "mobileNumber": { "type": "string" },
        "books": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "author": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "number" }
            },
            "required": ["id", "title", "price", "quantity"]
          }
        },
        "totalAmount": { "type": "number" },
        "orderDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Paid", "Shipped", "Delivered"] }
      },
      "required": ["userId", "customerName", "deliveryAddress", "mobileNumber", "books", "totalAmount", "orderDate", "status"]
    },
    "SyllabusTopic": {
      "title": "Syllabus Topic",
      "description": "Defines the topics and marks for a single subject within a syllabus.",
      "type": "object",
      "properties": {
        "marks": { "type": "number", "description": "Total marks for the subject." },
        "topics": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of topics covered in the subject."
        }
      },
      "required": ["marks", "topics"]
    },
    "Syllabus": {
      "title": "Syllabus",
      "description": "Represents the syllabus for a specific competition level.",
      "type": "object",
      "properties": {
        "level": { "type": "string", "description": "The competition level this syllabus applies to (e.g., '0.0', '1.5')." },
        "subjects": {
          "type": "object",
          "description": "A map of subject names to their topic details.",
          "additionalProperties": {
            "$ref": "#/backend/entities/SyllabusTopic"
          }
        }
      },
      "required": ["level", "subjects"]
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "Stores user profile information."
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/backend/entities/Order" },
      "description": "Stores customer book orders."
    },
    "/syllabi/{level}": {
      "schema": { "$ref": "#/backend/entities/Syllabus" },
      "description": "Stores the syllabus for each competition level."
    }
  }
}
